{
  "name": "alphanote",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AlphaNote — a markets research dashboard. Hybrid of ReturnSignal (React+Vite SPA shell, Plotly, Markdown export) and OpenStock (Finnhub data, TradingView charts, Claude→Gemini AI).",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "plotly.js-dist-min": "^2.35.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
