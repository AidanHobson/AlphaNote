{
  "name": "alphanote",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AlphaNote — a markets research dashboard. Hybrid of ReturnSignal (React+Vite SPA shell, Plotly, Markdown export) and OpenStock (Finnhub data, TradingView charts, Claude→Gemini AI).",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production node server/index.js",
    "test": "vitest run",
    "eval": "node scripts/eval.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jspdf": "^4.2.1",
    "plotly.js-basic-dist-min": "^2.35.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "typescript": "^5.6.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  }
}
