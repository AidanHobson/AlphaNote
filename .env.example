# =============================================================================
# AlphaNote — environment variables. Copy to `.env` and fill in. NEVER commit `.env`.
# =============================================================================

# ---- Server ----
PORT=8080
# NODE_ENV is set to "production" by `npm start`; leave unset for dev.

# ---- Finnhub (market data) — server-side only ----
FINNHUB_API_KEY=your_finnhub_key
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# ---- AI provider (Claude primary, Gemini fallback) ----
AI_PROVIDER=claude
AI_FALLBACK_PROVIDER=gemini

ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Economy: FRED (optional) ----
# Timely US macro series (CPI prints, Fed funds, live Treasury yield curve).
# Free key: https://fredaccount.stlouisfed.org/apikeys  (32-char lowercase).
# Leave blank to use the World Bank fallback (annual indicators, no key needed).
FRED_API_KEY=
