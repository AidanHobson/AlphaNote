# =============================================================================
# AlphaNote — environment variables. Copy to `.env` and fill in. NEVER commit `.env`.
# =============================================================================

# ---- Server ----
PORT=8080
# NODE_ENV is set to "production" by `npm start`; leave unset for dev.

# ---- Accounts (multi-user auth) ----
# User accounts, sessions and per-user watchlist/notes live in a local SQLite file.
# Optional: override the database path (defaults to ./alphanote.db, git-ignored).
# No auth secret is needed — sessions are random server-side tokens stored in the DB.
# DB_PATH=./alphanote.db

# ---- Finnhub (market data) — server-side only ----
FINNHUB_API_KEY=your_finnhub_key
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# ---- AI provider (Claude primary, Gemini fallback) ----
AI_PROVIDER=claude
AI_FALLBACK_PROVIDER=gemini

ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Insider Explorer: sec-api.io (optional) ----
# Structured market-wide Form 4 insider transactions (https://sec-api.io).
# When set, the Insider Explorer uses it for far more companies/transactions;
# otherwise it falls back to parsing SEC EDGAR's daily index directly.
SEC_API_KEY=
# How many sec-api.io pages (50 filings each) to pull — more = more transactions
# but slower first load + more API quota. The FREE sec-api plan has a small query
# limit, so keep this modest (default 24 ≈ ~2k transactions). On a paid plan you can
# raise it toward the max ~199 (~12k transactions).
INSIDER_PAGES=24

# ---- Insider Explorer backup: API Ninjas (optional) ----
# https://api-ninjas.com — used as a backup for the Insider Explorer (aggregated
# across a curated universe) when sec-api.io is unavailable.
NINJAS_API_KEY=

# ---- Economy: FRED (optional) ----
# Timely US macro series (CPI prints, Fed funds, live Treasury yield curve).
# Free key: https://fredaccount.stlouisfed.org/apikeys  (32-char lowercase).
# Leave blank to use the World Bank fallback (annual indicators, no key needed).
FRED_API_KEY=
